# compose.yml内で利用する環境変数の設定
COMPOSE_PROJECT_NAME=gpio_docker
CONTAINER_NAME=gpio_checker

Dockerfile_DIR=.
Dockerfile=Dockerfile

VOLUME=./linux_data

TIME_ZONE=Asia/Tokyo
LANG=ja_JP.UTF8

USER_NAME=PEN
PASSWORD=password

ENTRY_DIR=Programs
ENTRY_POINT=start.sh

WS=WS

# GPIOデバイス
# `gpiodetect` → "pinctrl-rp1"
GPIOMEM=/dev/gpiomem0
GPIOCHIP=/dev/gpiochip0